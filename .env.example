# ==============================================================================
# Docker Compose Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' (for development) or '.env.prod' (for production)
# and fill in the values before running docker compose.
# ==============================================================================

# ------------------------------------------------------------------------------
# Development Environment Variables (docker-compose.yml)
# ------------------------------------------------------------------------------
# MongoDB Root credentials used when starting the Mongo container in dev
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password123

# ------------------------------------------------------------------------------
# Production Environment Variables (docker-compose.prod.yml)
# ------------------------------------------------------------------------------
# Connection URI for the MongoDB service (points to the 'mongo' container service)
MONGO_URI=mongodb://mongo:27017/ai_interview_prep

# A strong secret key used for signing JSON Web Tokens (JWT) in production.
# Replace this with a randomly generated strong secret.
JWT_SECRET=replace_with_strong_random_secret_in_production

# ------------------------------------------------------------------------------
# LLM / AI Configuration (Groq)
# Get your API key at: https://console.groq.com
# Both LLM and Whisper use the same Groq API key.
# ------------------------------------------------------------------------------
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_REASONING=llama-3.3-70b-versatile
LLM_MODEL_EXTRACTION=llama-3.1-8b-instant
LLM_MODEL_JUDGE=llama-3.1-8b-instant

WHISPER_API_KEY=your_groq_api_key_here
WHISPER_BASE_URL=https://api.groq.com/openai/v1/audio/transcriptions
WHISPER_MODEL=whisper-large-v3
